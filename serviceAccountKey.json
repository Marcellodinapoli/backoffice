// scripts/setAdmin.js

const admin = require("firebase-admin");

// 🔑 Carica la chiave di servizio
const serviceAccount = require("./serviceAccountKey.json");

// 🔹 Inizializza l'admin SDK
admin.initializeApp({
credential: admin.credential.cert(serviceAccount),
});

// 🔹 Funzione per settare admin = true su un utente
async function setAdmin(uid) {
try {
await admin.auth().setCustomUserClaims(uid, { admin: true });
console.log(`✅ L'utente con UID: ${uid} ora è ADMIN`);
} catch (error) {
console.error("❌ Errore nel settare admin:", error);
}
}

// 🔹 Passa UID da terminale
const uid = process.argv[2];
if (!uid) {
console.error("❌ Devi passare l'UID:  node setAdmin.js <UID>");
process.exit(1);
}

setAdmin(uid);
